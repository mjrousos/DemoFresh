{
  "DemoFresh": {
    "Repos": [
      {
        "Url": "https://github.com/example/demo-repo",
        "Branch": "main",
        "Name": "Example Demo Repo"
      }
    ],
    "ActionMode": "CreatePR",
    "Model": "gpt-5",
    "ReportRecipient": "user@example.com",
    "Email": {
      "SmtpHost": "smtp.gmail.com",
      "SmtpPort": 587,
      "UseSsl": true,
      "SenderAddress": "your-email@gmail.com",
      "SenderName": "DemoFresh",
      "AppPassword": ""
    },
    "Context7": {
      "Enabled": true,
      "Command": "npx",
      "Args": ["-y", "@upstash/context7-mcp"],
      "ApiKey": ""
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.File"],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/demofresh-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
